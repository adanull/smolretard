# LN Markets API Credentials
# Get these from: https://app.lnmarkets.com/user/api
LNM_API_KEY=your_api_key_here
LNM_API_SECRET=your_api_secret_here
LNM_API_PASSPHRASE=your_passphrase_here

# Network: mainnet or testnet4
LNM_NETWORK=testnet4

# Bot mode: dry (paper trading) or live
BOT_MODE=dry

# Telegram notifications (optional, handled via OpenClaw)
# NOTIFY_CHAT_ID=your_telegram_chat_id
